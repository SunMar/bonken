# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Generated launcher icons and splash images (produced by tool/generate_icons.sh).
# The SVG sources in assets/icon/ are the source of truth. The glob also covers
# the resolution-variant subdirs (assets/icon/{2.0x,3.0x}/*.png).
/assets/icon/**/*.png
/web/favicon.png
/web/icons/Icon-*.png

# Download-page assets staged into web/ for web/download.html (logo rendered from
# the squircle SVG; store badges copied from the committed assets/store/ artwork).
/web/download-logo.png
/web/app_store_badge_nl.png
/web/google_play_badge_nl.png

# FVM Version Cache
.fvm/

# Generated store screenshots (produced by tool/generate_screenshots.dart).
/screenshots/

# Local scratch (font comparisons, downloaded candidates, etc.)
/tmp/
