# Generated launcher icons (produced by tool/generate_icons.sh).
# The SVG sources in assets/icon/ are the source of truth.
/assets/icon/*.png
/web/favicon.png
/web/icons/Icon-*.png

# FVM Version Cache
.fvm/

# Local scratch (font comparisons, downloaded candidates, etc.)
/tmp/
