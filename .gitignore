# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Generated launcher icons (produced by tool/generate_icons.sh).
# The SVG sources in assets/icon/ are the source of truth.
/assets/icon/*.png
/web/favicon.png
/web/icons/Icon-*.png
/android/app/src/main/res/mipmap-*/ic_launcher.png
/android/app/src/main/res/mipmap-anydpi-v26/ic_launcher.xml
/android/app/src/main/res/drawable-*/ic_launcher_*.png
